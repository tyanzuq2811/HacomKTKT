# HSDT Peer Comparison 7.2 — so sánh ngang hàng, chạy trực tiếp theo kiến trúc standalone
HSMT_STRICT_PRIVACY=1
HSMT_ALLOW_NETWORK=0
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
DO_NOT_TRACK=1

# Web/job store nội bộ
HSMT_RUNTIME_ROOT=runtime/jobs
HSMT_JOB_RETENTION_HOURS=24
HSMT_MAX_CONCURRENT_JOBS=2
HSMT_MAX_UPLOAD_MB=2048
HSMT_MAX_EXCEL_ROWS=1000000

# Model matching cục bộ; production không tự tải từ Internet.
HSMT_MODEL_ROOT=D:/HSMT_MODELS
HSMT_EMBEDDING_MODEL=D:/HSMT_MODELS/Qwen3-Embedding-0.6B
HSMT_RERANKER_MODEL=D:/HSMT_MODELS/Qwen3-Reranker-0.6B
HSMT_ENABLE_EMBEDDINGS=1
HSMT_ENABLE_RERANKER=1
HSMT_EMBED_BATCH=32
HSMT_RERANK_BATCH=16
HSMT_FUZZY_TOP_K=8

# OCR cục bộ — dùng khi cài requirements-ocr-cpu/gpu.txt
HSMT_PADDLE_REC_MODEL_DIR=D:/HSMT_MODELS/latin_PP-OCRv5_mobile_rec
HSMT_PADDLE_REC_MODEL_NAME=latin_PP-OCRv5_mobile_rec
HSMT_PADDLE_OCR_YAML=D:/HSMT_MODELS/config/ocr_v5_local.yaml
HSMT_TABLEMAGIC_YAML=D:/HSMT_MODELS/config/tablemagic_v2_local.yaml
HSMT_PPSTRUCTURE_YAML=D:/HSMT_MODELS/config/ppstructure_v3_local.yaml
HSMT_PADDLE_VL_YAML=D:/HSMT_MODELS/config/paddleocr_vl_1_6_local.yaml
HSMT_OCR_DEVICE=gpu:0
HSMT_OCR_DPI=300
HSMT_OCR_UPSCALE=3
HSMT_OCR_WORKERS=1
HSMT_MAX_PDF_PAGES=500
